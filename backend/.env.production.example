# Copy to /opt/service-call/backend/.env on the server and fill in real values.
# This file (the real .env) is gitignored — never commit secrets.

APP_ENV=production
# Disable the email-only dev login in production.
ENABLE_DEV_LOGIN=false

# Long random secret: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME

# Same-origin behind nginx, so CORS is not needed; left explicit for clarity.
CORS_ORIGINS=https://service-call.newavera.co.il

# SQLite is the default (database/servicecall.db). To switch to Postgres later:
# DATABASE_URL=postgresql+pg8000://user:pass@localhost:5432/servicecall

# Initial admin (created/reset by: python -m app.bootstrap)
SEED_ADMIN_EMAIL=boazen@gmail.com
SEED_ADMIN_PASSWORD=CHANGE_ME

# ===== Priority (OData 4.0) — real ebyael environment =====
PRIORITY_USE_MOCK=false
PRIORITY_BASE_URL=https://p.priority-connect.online/odata/Priority/tabz0qun.ini/ebyael
PRIORITY_COMPANY=ebyael
PRIORITY_USER=CHANGE_ME
PRIORITY_PASSWORD=CHANGE_ME
PRIORITY_SERVICE_ENTITY=DOCUMENTS_Q
PRIORITY_ACTIVE_ONLY=false
