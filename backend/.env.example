# Copy to backend/.env and fill in. A shared env at
# C:\Users\User\Aiprojects\env\.env is also read (this file overrides it).

# --- App ---
APP_NAME=TACT Service-Call
APP_ENV=development

# --- Database ---
# Local dev defaults to SQLite at database/servicecall.db. For Postgres:
# DATABASE_URL=postgresql+pg8000://sc:sc@localhost:5432/servicecall

# --- CORS (frontend origin) ---
CORS_ORIGINS=http://localhost:5300

# --- JWT (set a long random value in production) ---
JWT_SECRET=dev-secret-change-in-prod

# --- Priority ERP integration ---
# Leave PRIORITY_USE_MOCK=true until the real API is wired; then set it false
# and fill the connection details below.
PRIORITY_USE_MOCK=true
PRIORITY_BASE_URL=
PRIORITY_COMPANY=
PRIORITY_USER=
PRIORITY_PASSWORD=
PRIORITY_SERVICE_ENTITY=SERVCALLS
