[Unit]
Description=TACT Service-Call API (FastAPI/uvicorn)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/service-call/backend
# Single worker — SQLite + WAL handles the concurrency of an internal tool.
ExecStart=/opt/service-call/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8020
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
